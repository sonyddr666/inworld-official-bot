# =============================================
# Configuração do Bot Inworld - Coolify / .env
# =============================================

# OBRIGATÓRIO: Token do bot do Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=

# OPCIONAL: IDs Telegram dos admins, separados por vírgula
# Admins podem usar /setglobalkey para mudar a chave global via Telegram
# Ex: TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_ADMIN_IDS=

# OPCIONAL: Chave global padrão da Inworld (fallback para usuários sem chave própria)
# Formato: key_id:key_secret   OU   Basic BASE64
# Se não configurada, cada usuário deve inserir a própria chave via /apikey
INWORLD_BASE64_CREDENTIAL=

# OPCIONAL: Voz padrão ao iniciar
INWORLD_DEFAULT_VOICE_ID=

# OPCIONAL: Máximo de caracteres por requisição (padrão: 1900)
INWORLD_MAX_CHARS_PER_REQUEST=1900

# OPCIONAL: Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
